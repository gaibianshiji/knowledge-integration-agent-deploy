    {
      "id": "book_de7fdf2c_node_001",
      "name": "组织学",
      "definition": "研究机体微细结构及其与功能关系的科学，又称显微解剖学。",
      "category": "核心概念",
      "chapter": "第1章 组织学绪论",
      "page": 2,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_002",
      "name": "光学显微镜技术",
      "definition": "使用光学显微镜观察组织切片的技术，是组织学最基本的研究方法。",
      "category": "核心概念",
      "chapter": "第1章 组织学绪论",
      "page": 3,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_003",
      "name": "电子显微镜技术",
      "definition": "使用电子显微镜观察组织超微结构的技术，分辨率远高于光镜。",
      "category": "核心概念",
      "chapter": "第1章 组织学绪论",
      "page": 4,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_004",
      "name": "组织化学技术",
      "definition": "利用化学或物理方法在组织切片上显示特定化学成分的技术。",
      "category": "核心概念",
      "chapter": "第1章 组织学绪论",
      "page": 4,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_005",
      "name": "上皮组织",
      "definition": "由大量紧密排列的上皮细胞和少量细胞间质构成，覆盖于体表或衬于管腔。",
      "category": "核心概念",
      "chapter": "第2章 上皮组织",
      "page": 9,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_006",
      "name": "被覆上皮",
      "definition": "覆盖于身体表面或衬于体腔、管腔、囊腔等内表面的上皮组织。",
      "category": "核心概念",
      "chapter": "第2章 上皮组织",
      "page": 9,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_007",
      "name": "腺上皮和腺",
      "definition": "以分泌功能为主的上皮称为腺上皮，以腺上皮为主要成分的器官称为腺。",
      "category": "核心概念",
      "chapter": "第2章 上皮组织",
      "page": 13,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_008",
      "name": "结缔组织",
      "definition": "由少量细胞和大量细胞间质构成，具有连接、支持、营养、保护等功能。",
      "category": "核心概念",
      "chapter": "第3章 结缔组织",
      "page": 20,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_009",
      "name": "疏松结缔组织",
      "definition": "细胞种类多、纤维少、基质丰富，结构疏松，分布广泛。",
      "category": "核心概念",
      "chapter": "第3章 结缔组织",
      "page": 20,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_010",
      "name": "软骨组织",
      "definition": "由软骨细胞和细胞间质构成，具有一定的弹性和韧性。",
      "category": "核心概念",
      "chapter": "第4章 软骨和骨",
      "page": 29,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_011",
      "name": "骨组织",
      "definition": "由骨细胞和钙化的细胞间质构成，是人体最坚硬的结缔组织。",
      "category": "核心概念",
      "chapter": "第4章 软骨和骨",
      "page": 31,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_012",
      "name": "血液",
      "definition": "流动于心血管系统中的液态结缔组织，由血浆和血细胞组成。",
      "category": "核心概念",
      "chapter": "第5章 血液",
      "page": 41,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_013",
      "name": "肌组织",
      "definition": "由肌细胞构成，具有收缩功能，分为骨骼肌、心肌和平滑肌。",
      "category": "核心概念",
      "chapter": "第6章 肌组织",
      "page": 52,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_014",
      "name": "神经组织",
      "definition": "由神经元和神经胶质细胞构成，是神经系统的主要组成成分。",
      "category": "核心概念",
      "chapter": "第7章 神经组织",
      "page": 60,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_015",
      "name": "神经元",
      "definition": "神经系统的结构和功能单位，具有感受刺激和传导神经冲动的能力。",
      "category": "核心概念",
      "chapter": "第7章 神经组织",
      "page": 60,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_016",
      "name": "突触",
      "definition": "神经元之间或神经元与效应细胞之间传递信息的特化接触结构。",
      "category": "核心概念",
      "chapter": "第7章 神经组织",
      "page": 63,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_017",
      "name": "神经系统",
      "definition": "由神经组织构成，调节机体各系统活动，适应内外环境变化的系统。",
      "category": "核心概念",
      "chapter": "第8章 神经系统",
      "page": 75,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_018",
      "name": "循环系统",
      "definition": "由心脏和血管组成的封闭管道系统，负责输送血液和营养物质。",
      "category": "核心概念",
      "chapter": "第9章 循环系统",
      "page": 83,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_019",
      "name": "动脉和静脉管壁的一般结构",
      "definition": "由内膜、中膜和外膜三层构成，是血管壁的基本结构模式。",
      "category": "核心概念",
      "chapter": "第9章 循环系统",
      "page": 83,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    },
    {
      "id": "book_de7fdf2c_node_020",
      "name": "毛细血管",
      "definition": "管径最细、分布最广的血管，是血液与组织液进行物质交换的场所。",
      "category": "核心概念",
      "chapter": "第9章 循环系统",
      "page": 87,
      "textbook_id": "book_de7fdf2c",
      "textbook_name": "de7fdf2c"
    }
