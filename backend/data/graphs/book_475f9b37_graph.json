      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_035",
      "name": "颈静脉孔",
      "definition": "位于颅后窝，舌咽神经、迷走神经、副神经和颈内静脉由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_036",
      "name": "舌下神经管",
      "definition": "位于颅后窝枕骨髁上方，舌下神经由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_037",
      "name": "内耳门",
      "definition": "位于颅后窝颞骨岩部后面，面神经和前庭蜗神经由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_038",
      "name": "枕骨大孔",
      "definition": "位于颅后窝中央，延髓与脊髓交界处及椎动脉由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_039",
      "name": "头部解剖操作",
      "definition": "对头部进行系统解剖的操作流程，包括面部和颅部的解剖步骤。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_040",
      "name": "解剖面部",
      "definition": "头部解剖操作的一部分，涉及面部结构的分离和暴露。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_041",
      "name": "解剖颅部",
      "definition": "头部解剖操作的一部分，涉及颅骨及颅内结构的暴露和观察。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_042",
      "name": "面部解剖步骤",
      "definition": "解剖面部时的具体操作顺序和方法，包括皮肤切开、浅筋膜分离等。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
