      "page": 30,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_045",
      "name": "面部深层结构",
      "definition": "面部深层包括咬肌、颊肌、腮腺、面神经分支及血管等结构。",
      "category": "解剖结构",
      "chapter": "第四节 头部解剖操作",
      "page": 30,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
