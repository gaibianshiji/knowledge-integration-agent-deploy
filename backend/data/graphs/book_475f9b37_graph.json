  "nodes": [
    {
      "id": "book_475f9b37_node_001",
      "name": "局部解剖学",
      "definition": "研究人体各局部由浅入深的层次结构、形态、位置、毗邻关系及其临床应用的科学。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_002",
      "name": "境界与分区",
      "definition": "描述人体各局部之间的边界划分以及内部区域的细分，是局部解剖学的基础内容。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_003",
      "name": "表面解剖",
      "definition": "通过观察和触摸体表标志（如骨性突起、肌性隆起、皮肤皱纹等）来推断内部结构的位置。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_004",
      "name": "体表标志",
      "definition": "位于人体表面的骨性、肌性或皮肤性标志，用于定位深层结构。",
      "category": "解剖结构",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_005",
      "name": "骨性标志",
      "definition": "体表可触及的骨性突起或凹陷，如髂前上棘、肩胛骨下角等。",
      "category": "解剖结构",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_006",
      "name": "肌性标志",
      "definition": "体表可见或可触及的肌肉轮廓或肌腱，如胸锁乳突肌、肱二头肌肌腱等。",
      "category": "解剖结构",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_007",
      "name": "皮肤标志",
      "definition": "体表皮肤上的皱纹、凹陷或特殊纹理，如掌纹、腋前襞等。",
      "category": "解剖结构",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_008",
      "name": "局部划分",
      "definition": "将人体分为头部、颈部、躯干、四肢等主要部分，并进一步细分区域。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_009",
      "name": "临床应用",
      "definition": "局部解剖学知识在手术、穿刺、体格检查等临床操作中的实际应用。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_010",
      "name": "层次结构",
      "definition": "人体各局部由浅入深依次排列的皮肤、皮下组织、筋膜、肌肉、血管神经等结构。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 14,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_011",
      "name": "面部浅层结构",
      "definition": "面部皮肤、浅筋膜、表情肌及浅层血管、神经等结构的总称。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_012",
      "name": "面侧区",
      "definition": "面部两侧的区域，包含腮腺、咬肌、面神经等深层重要结构。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_013",
      "name": "面部的间隙",
      "definition": "面部筋膜之间形成的潜在腔隙，如咬肌间隙、翼下颌间隙等，是感染扩散的途径。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 19,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_014",
      "name": "面部皮肤",
      "definition": "面部皮肤薄而柔软，血供丰富，富含皮脂腺和汗腺，是表情肌的附着点。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_015",
      "name": "浅筋膜",
      "definition": "面部浅筋膜疏松，内含表情肌、血管、神经和脂肪组织，与皮肤连接紧密。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_016",
      "name": "表情肌",
      "definition": "起于骨面或筋膜，止于皮肤，收缩时牵动皮肤产生表情的肌肉群。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_017",
      "name": "腮腺",
      "definition": "位于面侧区，是最大的唾液腺，其浅面有皮肤和浅筋膜覆盖，深面邻接咬肌和下颌支。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_018",
      "name": "咬肌",
      "definition": "位于面侧区，起于颧弓，止于下颌角，是主要的咀嚼肌之一。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_019",
      "name": "面神经",
      "definition": "支配面部表情肌的混合神经，从茎乳孔出颅后进入腮腺，分为五支分布于面部。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_020",
      "name": "咬肌间隙",
      "definition": "位于咬肌与下颌支之间的潜在间隙，是面部常见的感染扩散通道。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 19,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_021",
      "name": "翼下颌间隙",
      "definition": "位于翼内肌与下颌支之间的潜在间隙，与咬肌间隙相通，是牙源性感染扩散的重要途径。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 19,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_022",
      "name": "面部浅层血管",
      "definition": "包括面动脉、面静脉等，分布于面部浅层，为面部提供血供和回流。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_023",
      "name": "面部浅层神经",
      "definition": "包括三叉神经的皮支和面神经的终末支，负责面部的感觉和运动。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_024",
      "name": "颅部",
      "definition": "头部的重要组成部分，包含颅骨、脑及其被膜、血管、神经等结构。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 20,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_025",
      "name": "颅底内面",
      "definition": "颅腔的底部内表面，分为颅前窝、颅中窝和颅后窝，有多个孔裂供神经血管通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_026",
      "name": "颅前窝",
      "definition": "颅底内面前部，容纳大脑额叶，由额骨、筛骨和蝶骨小翼构成。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_027",
      "name": "颅中窝",
      "definition": "颅底内面中部，容纳大脑颞叶和垂体，由蝶骨体和颞骨岩部构成。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_028",
      "name": "颅后窝",
      "definition": "颅底内面后部，容纳小脑和脑干，由枕骨和颞骨岩部后面构成。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_029",
      "name": "筛孔",
      "definition": "位于颅前窝筛骨筛板上的小孔，嗅神经纤维由此通过进入鼻腔。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_030",
      "name": "视神经管",
      "definition": "位于颅中窝蝶骨小翼根部，视神经和眼动脉由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_031",
      "name": "眶上裂",
      "definition": "位于颅中窝蝶骨大小翼之间，动眼神经、滑车神经、展神经和三叉神经眼支由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_032",
      "name": "圆孔",
      "definition": "位于颅中窝蝶骨大翼，三叉神经上颌支由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_033",
      "name": "卵圆孔",
      "definition": "位于颅中窝蝶骨大翼，三叉神经下颌支和脑膜副动脉由此通过。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_475f9b37",
      "textbook_name": "局部解剖学"
    },
    {
      "id": "book_475f9b37_node_034",
      "name": "棘孔",
      "definition": "位于颅中窝蝶骨大翼，脑膜中动脉由此入颅。",
