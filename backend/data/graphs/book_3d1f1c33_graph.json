{
  "textbook_id": "book_3d1f1c33",
  "textbook_name": "3d1f1c33",
  "nodes": [
    {
      "id": "book_3d1f1c33_node_001",
      "name": "适应",
      "definition": "细胞、组织或器官对内外环境刺激做出的非损伤性应答反应，包括萎缩、肥大、增生和化生。",
      "category": "核心概念",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_002",
      "name": "萎缩",
      "definition": "已发育正常的细胞、组织或器官体积缩小，可因细胞数量减少或体积减小所致。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_003",
      "name": "肥大",
      "definition": "细胞、组织或器官体积增大，常因细胞体积增大所致，可伴细胞数量增加。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_004",
      "name": "增生",
      "definition": "实质细胞数量增多，导致组织或器官体积增大，常与肥大并存。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_005",
      "name": "化生",
      "definition": "一种分化成熟的细胞类型被另一种分化成熟的细胞类型所取代的过程，通常为适应性改变。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_006",
      "name": "细胞老化",
      "definition": "细胞随年龄增长或受内外因素影响，出现功能减退、增殖能力下降及形态改变的过程。",
      "category": "生理机制",
      "chapter": "第一节　适应",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_007",
      "name": "生理性萎缩",
      "definition": "正常生理过程中发生的萎缩，如青春期后胸腺萎缩、老年性器官萎缩。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_008",
      "name": "病理性萎缩",
      "definition": "由疾病或异常刺激引起的萎缩，如营养不良性萎缩、压迫性萎缩。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_009",
      "name": "代偿性肥大",
      "definition": "因功能需求增加导致的器官或组织体积增大，如高血压引起的心肌肥大。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_010",
      "name": "内分泌性肥大",
      "definition": "激素刺激引起的细胞体积增大，如妊娠期子宫平滑肌肥大。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_011",
      "name": "再生性增生",
      "definition": "组织损伤后通过细胞分裂增殖以恢复原有结构和功能，如肝细胞再生。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_012",
      "name": "鳞状上皮化生",
      "definition": "柱状上皮或移行上皮被鳞状上皮取代，常见于慢性支气管炎时气管黏膜。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_013",
      "name": "肠上皮化生",
      "definition": "胃黏膜上皮被肠型上皮取代，与慢性胃炎及胃癌发生相关。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_014",
      "name": "细胞和组织损伤的原因",
      "definition": "导致细胞和组织结构或功能异常的各种因素，包括物理、化学、生物、营养、免疫、遗传等。",
      "category": "核心概念",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_015",
      "name": "细胞和组织损伤的机制",
      "definition": "细胞和组织在损伤因素作用下发生病理变化的内在生物学过程，涉及ATP耗竭、自由基损伤、钙超载等。",
      "category": "核心概念",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_016",
      "name": "物理性损伤因素",
      "definition": "包括机械力、温度（高温、低温）、辐射、电击等物理因素导致的细胞损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_017",
      "name": "化学性损伤因素",
      "definition": "包括化学毒物、药物、酒精、强酸强碱、重金属等化学物质引起的细胞损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_018",
      "name": "生物性损伤因素",
      "definition": "包括病毒、细菌、真菌、寄生虫等病原微生物感染导致的细胞和组织损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_019",
      "name": "营养失衡",
      "definition": "由于营养物质缺乏（如蛋白质、维生素、微量元素）或过剩（如肥胖）导致的细胞代谢异常和损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_020",
      "name": "免疫反应异常",
      "definition": "包括自身免疫反应、过敏反应、免疫缺陷等导致的细胞和组织损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_021",
      "name": "遗传因素",
      "definition": "基因突变、染色体异常等遗传缺陷导致细胞结构或功能异常，引起损伤。",
      "category": "病理变化",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_022",
      "name": "ATP耗竭",
      "definition": "细胞能量代谢障碍导致ATP生成不足，影响钠钾泵、蛋白质合成等关键生命活动，引发细胞损伤。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_023",
      "name": "自由基损伤",
      "definition": "活性氧等自由基产生过多或清除不足，攻击细胞膜、蛋白质、DNA等生物大分子，导致细胞损伤。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_024",
      "name": "钙超载",
      "definition": "细胞内钙离子浓度异常升高，激活多种酶类（如磷脂酶、蛋白酶、核酸内切酶），破坏细胞结构。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_025",
      "name": "缺氧",
      "definition": "组织氧供应不足或细胞利用氧障碍，导致线粒体氧化磷酸化受阻，ATP合成减少，是常见损伤机制。",
      "category": "生理机制",
      "chapter": "第二节　细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_026",
      "name": "细胞可逆性损伤",
      "definition": "细胞受到轻度或短时间刺激后，发生的可恢复的形态和功能改变，包括细胞水肿、脂肪变等。",
      "category": "核心概念",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 14,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_027",
      "name": "细胞水肿",
      "definition": "细胞因缺氧、中毒等导致钠水潴留，胞浆内水分增多，细胞体积增大的可逆性损伤。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 15,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_028",
      "name": "脂肪变",
      "definition": "非脂肪细胞胞浆内出现甘油三酯或中性脂肪滴的病理过程，常见于肝、心、肾等器官。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 15,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_029",
      "name": "玻璃样变",
      "definition": "细胞内或间质中出现均质、半透明的玻璃样物质，又称透明变性，常见于血管壁、结缔组织等。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 16,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_030",
      "name": "淀粉样变",
      "definition": "细胞外间质中出现淀粉样蛋白沉积，HE染色呈粉红色，刚果红染色阳性，常见于慢性炎症或浆细胞病。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 16,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_031",
      "name": "黏液样变",
      "definition": "间质内出现黏多糖和蛋白质的积聚，常见于甲状腺功能减退、风湿病等。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_032",
      "name": "病理性色素沉着",
      "definition": "细胞内或间质中异常色素（如含铁血黄素、胆红素、黑色素等）的沉积，反映代谢或损伤状态。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_033",
      "name": "病理性钙化",
      "definition": "钙盐在骨和牙齿以外的软组织中的异常沉积，包括营养不良性钙化和转移性钙化。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_034",
      "name": "营养不良性钙化",
      "definition": "局部组织坏死或损伤后，钙盐在坏死灶或瘢痕中沉积，血钙正常。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    },
    {
      "id": "book_3d1f1c33_node_035",
      "name": "转移性钙化",
      "definition": "因高钙血症导致钙盐在正常组织中沉积，常见于肾、肺、胃黏膜等。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_3d1f1c33",
      "textbook_name": "3d1f1c33"
    }
  ],
