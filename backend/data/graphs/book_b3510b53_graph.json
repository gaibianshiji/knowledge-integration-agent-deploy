    },
    {
      "id": "book_b3510b53_node_015",
      "name": "微生物与人类的关系",
      "definition": "微生物对人类既有有益方面（如参与物质循环、生产抗生素），也有有害方面（如引起疾病）。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_016",
      "name": "医学微生物学发展的主要阶段",
      "definition": "从经验时期、实验时期到现代分子生物学时期的发展历程，包括关键发现和技术突破。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_017",
      "name": "郭霍法则",
      "definition": "由郭霍提出的判断某种微生物是否为特定传染病病原体的四条标准，是病原学鉴定的经典法则。",
      "category": "核心概念",
      "chapter": "第三节　微生态失调的防治",
      "page": 19,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_018",
      "name": "微生物",
      "definition": "广泛存在于自然界中，肉眼直接观察不到，须借助光学显微镜或电子显微镜放大数百倍甚至数万倍才能观察到的微小生物。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_019",
      "name": "真核细胞型微生物",
      "definition": "有典型细胞结构，细胞器完整，细胞核分化程度高，有核膜和核仁，DNA为遗传物质的一类微生物，如真菌。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_020",
      "name": "原核细胞型微生物",
      "definition": "有细胞基本结构，仅有核糖体，细胞核分化程度低，为原始核质，无核膜和核仁，DNA为遗传物质的一类微生物，包括古菌和细菌。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_021",
      "name": "非细胞型微生物",
      "definition": "最小的一类微生物，无细胞结构，无产生能量的酶系统，只能寄生在活细胞内生长增殖，只有一种类型遗传物质（DNA或RNA），如病毒。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_022",
      "name": "古菌",
      "definition": "原核细胞型微生物的一类，不能合成肽聚糖，具有独特代谢方式，能在高盐或低温等极端环境下生存，在人体内也有分布，但尚未发现对人类的致病性。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_023",
      "name": "细菌",
      "definition": "原核细胞型微生物的一类，具有细胞壁，与人体健康密切相关，少数对人有致病性。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_024",
      "name": "病毒",
      "definition": "非细胞型微生物，无细胞结构，只能寄生在活细胞内生长增殖，遗传物质为DNA或RNA。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_025",
      "name": "真菌",
      "definition": "真核细胞型微生物，具有典型细胞结构，细胞器完整，细胞核分化程度高。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_026",
      "name": "病原微生物",
      "definition": "少数具有致病性，能引起人类、动物和植物感染性疾病的微生物。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_027",
      "name": "机会致病性微生物",
      "definition": "在正常情况下寄生在人体内不致病，但在特定情况下会导致人类疾病的微生物，如大肠埃希菌。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_028",
      "name": "微生物群",
      "definition": "定居在地球表面特定空间或生境的不同种类和数量的微生物。",
      "category": "核心概念",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_029",
      "name": "微生物的生态作用",
      "definition": "微生物参与生物圈碳、氮等物质的循环，维持生态环境平衡，如土壤微生物将有机氮转化为无机氮供植物利用。",
      "category": "生理机制",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_030",
      "name": "微生物在农业中的应用",
      "definition": "利用微生物分解有机物质进行沤粪积肥，开发微生物饲料、肥料、农药、食品、能源和环保制剂等。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_031",
      "name": "微生物在工业中的应用",
      "definition": "微生物在食品、采矿和新能源等领域应用广泛，如发酵生产抗生素、冶金浸矿、石油勘探等。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_032",
      "name": "微生物在环境保护中的应用",
      "definition": "微生物能够处理污水废气，降解有毒物质如苯、甲苯、汞等，通过氧化还原和分解作用净化环境。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_033",
      "name": "微生物与人类健康的关系",
      "definition": "正常情况下，寄生在人体内的微生物无害，可帮助消化、合成营养物质、调节免疫代谢，拮抗病原微生物入侵。",
      "category": "生理机制",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_034",
      "name": "微生物在科研中的应用",
      "definition": "微生物常被用作模式生物，基因表达、翻译及调控等规律首先在微生物中发现，并提供工具酶和载体系统用于基因工程。",
      "category": "治疗方法",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_035",
      "name": "微生物的致病性",
      "definition": "少数微生物具有致病性，能引起人类、动物和植物的感染性疾病，如志贺菌引起痢疾，结核分枝杆菌引起结核病。",
      "category": "病理变化",
      "chapter": "第一节 微生物和病原微生物",
      "page": 20,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_036",
      "name": "微生物学",
      "definition": "研究微生物的种类、遗传和变异，及其与人类、植物以及自然界相互关系的生命科学领域。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_037",
      "name": "医学微生物学",
      "definition": "研究与医学有关的病原微生物的生物学特性、致病机制、抗感染免疫机制及感染性疾病防治措施的学科。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_038",
      "name": "微生物学分支学科（按基本问题）",
      "definition": "包括微生物分类学、微生物生理学、微生物生态学、微生物遗传学、微生物基因组学等。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_039",
      "name": "微生物学分支学科（按研究对象）",
      "definition": "包括细菌学、真菌学、病毒学等。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_040",
      "name": "微生物学分支学科（按应用领域）",
      "definition": "包括医学微生物学、食品微生物学、农业微生物学、工业微生物学等。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_041",
      "name": "病原微生物",
      "definition": "医学微生物学主要研究的对象，指能引起人类疾病的微生物。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_042",
      "name": "生物学特性",
      "definition": "病原微生物的形态、结构、代谢、生长繁殖等基本特征。",
      "category": "核心概念",
      "chapter": "第二节 微生物学和医学微生物学",
      "page": 21,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
