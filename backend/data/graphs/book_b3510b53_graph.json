    {
      "id": "book_b3510b53_node_054",
      "name": "巴斯德",
      "definition": "法国科学家，通过曲颈瓶实验推翻自然发生说，创立巴氏消毒法，开创微生物生理学。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 23,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_055",
      "name": "郭霍法则",
      "definition": "1884年郭霍提出，用于确定病原微生物的四个标准：1) 在患者中查见，健康人无；2) 可分离纯培养；3) 接种易感动物产生同样病症；4) 可重新分离纯培养。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 23,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
    {
      "id": "book_b3510b53_node_056",
      "name": "病毒的发现",
      "definition": "1892年伊凡诺夫斯基发现烟草花叶病病毒，1898年发现口蹄疫病毒，1901年发现黄热病病毒。",
      "category": "核心概念",
      "chapter": "医学微生物学发展简史",
      "page": 24,
      "textbook_id": "book_b3510b53",
      "textbook_name": "b3510b53"
    },
