{
  "textbook_id": "book_dd048971",
  "textbook_name": "dd048971",
  "nodes": [
    {
      "id": "book_dd048971_node_001",
      "name": "适应",
      "definition": "细胞、组织或器官在受到环境刺激或损伤时，通过改变自身结构、代谢或功能以维持稳态的过程。",
      "category": "核心概念",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_002",
      "name": "萎缩",
      "definition": "已发育正常的细胞、组织或器官体积缩小，常伴细胞数量减少，是适应性反应的一种。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 5,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_003",
      "name": "肥大",
      "definition": "细胞、组织或器官体积增大，由实质细胞体积增大所致，可伴细胞数量增加，是适应性反应的一种。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 7,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_004",
      "name": "增生",
      "definition": "组织或器官内实质细胞数量增多，导致体积增大，是适应性反应的一种。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_005",
      "name": "化生",
      "definition": "一种分化成熟的细胞类型被另一种分化成熟的细胞类型所取代的过程，是适应性反应的一种。",
      "category": "病理变化",
      "chapter": "第一节　适应",
      "page": 8,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_006",
      "name": "细胞老化",
      "definition": "细胞随年龄增长或受内外因素影响，出现功能衰退、增殖能力下降、最终走向死亡的渐进性过程。",
      "category": "生理机制",
      "chapter": "第一节　适应",
      "page": 10,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_007",
      "name": "细胞和组织损伤的原因",
      "definition": "导致细胞和组织结构或功能异常的各种外部和内部因素，是损伤发生的起始环节。",
      "category": "核心概念",
      "chapter": "第二节 细胞和组织损伤的原因和机制",
      "page": 10,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_008",
      "name": "细胞和组织损伤的机制",
      "definition": "在损伤原因作用下，细胞内发生的导致结构或功能异常的分子和生化过程，是损伤发展的内在途径。",
      "category": "核心概念",
      "chapter": "第二节 细胞和组织损伤的原因和机制",
      "page": 11,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_009",
      "name": "细胞可逆性损伤",
      "definition": "细胞受到轻度损伤后，通过去除病因可恢复正常结构和功能的病理过程。",
      "category": "核心概念",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 14,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_010",
      "name": "细胞水肿",
      "definition": "细胞因水钠潴留而肿胀，是细胞损伤最早出现的形态学改变，常见于缺氧、中毒等。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 15,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_011",
      "name": "脂肪变",
      "definition": "非脂肪细胞胞质内出现甘油三酯或中性脂肪的异常蓄积，常见于肝脏、心脏等器官。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 15,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_012",
      "name": "玻璃样变",
      "definition": "细胞内或间质中出现均质、半透明的玻璃样物质，又称透明变性，常见于结缔组织、血管壁等。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 16,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_013",
      "name": "淀粉样变",
      "definition": "细胞外出现淀粉样物质（β-折叠片层结构的蛋白质）沉积，常累及肝、肾、脾等器官。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 16,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_014",
      "name": "黏液样变",
      "definition": "间质内出现黏多糖和蛋白质的异常积聚，常见于间叶组织肿瘤、风湿病等。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_015",
      "name": "病理性色素沉着",
      "definition": "细胞内或间质内出现异常色素（如含铁血黄素、胆红素、黑色素等）的沉积。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 17,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_016",
      "name": "病理性钙化",
      "definition": "在骨和牙齿以外的软组织内出现钙盐（磷酸钙、碳酸钙）的异常沉积，分为营养不良性钙化和转移性钙化。",
      "category": "病理变化",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 18,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_017",
      "name": "可逆性损伤的病因",
      "definition": "导致细胞可逆性损伤的常见因素，包括缺氧、化学毒物、感染、营养失衡等。",
      "category": "核心概念",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 14,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_018",
      "name": "可逆性损伤的恢复机制",
      "definition": "去除病因后，细胞通过修复机制（如离子泵恢复、蛋白质降解等）恢复正常结构和功能。",
      "category": "生理机制",
      "chapter": "第三节　细胞可逆性损伤",
      "page": 14,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_019",
      "name": "细胞不可逆性损伤",
      "definition": "细胞遭受严重损伤后，无法恢复其正常结构和功能，最终导致细胞死亡的病理过程。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 13,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_020",
      "name": "坏死",
      "definition": "细胞受到严重损伤后，细胞膜完整性破坏，细胞内容物释放，引起周围组织炎症反应的被动性细胞死亡形式。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 19,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_021",
      "name": "凋亡",
      "definition": "由基因调控的、细胞自主有序的主动性死亡过程，细胞膜保持完整，不引起炎症反应。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 21,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_022",
      "name": "坏死性凋亡",
      "definition": "一种受调控的坏死样细胞死亡形式，兼具凋亡的调控机制和坏死的形态学特征。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 23,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_023",
      "name": "细胞焦亡",
      "definition": "一种依赖于炎性半胱天冬酶（caspase-1/4/5/11）的促炎性细胞死亡方式，常伴随炎症小体激活。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 23,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_024",
      "name": "铁死亡",
      "definition": "一种铁依赖性的、以脂质过氧化为特征的调节性细胞死亡形式，区别于凋亡、坏死等。",
      "category": "病理变化",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 24,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_025",
      "name": "自噬",
      "definition": "细胞通过溶酶体降解自身受损细胞器或大分子物质，以维持稳态的代谢过程，过度时可导致细胞死亡。",
      "category": "生理机制",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 24,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_026",
      "name": "细胞死亡",
      "definition": "细胞生命活动不可逆终止的状态，是细胞不可逆性损伤的最终结果。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 13,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_027",
      "name": "调节性细胞死亡",
      "definition": "由特定分子信号通路调控的细胞死亡过程，包括凋亡、坏死性凋亡、焦亡、铁死亡等。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 19,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_028",
      "name": "被动性细胞死亡",
      "definition": "细胞遭受严重物理、化学或生物损伤后，不依赖特定信号通路而发生的死亡，典型代表为坏死。",
      "category": "核心概念",
      "chapter": "第四节　细胞不可逆性损伤",
      "page": 19,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_029",
      "name": "细胞周期",
      "definition": "细胞从一次分裂结束到下一次分裂结束所经历的有序过程，包括间期和分裂期。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 25,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_030",
      "name": "不同类型细胞的再生潜能",
      "definition": "根据细胞增殖能力将细胞分为不稳定细胞、稳定细胞和永久性细胞，其再生能力依次递减。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 25,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_031",
      "name": "不稳定细胞",
      "definition": "持续分裂的细胞，再生能力强，如皮肤表皮细胞、消化道黏膜上皮细胞。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 25,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_032",
      "name": "稳定细胞",
      "definition": "处于静止期但具有增殖潜能的细胞，受刺激后可进入细胞周期，如肝细胞、肾小管上皮细胞。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 25,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_033",
      "name": "永久性细胞",
      "definition": "出生后几乎完全丧失分裂能力的细胞，如神经元、心肌细胞，损伤后不能再生。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 25,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_034",
      "name": "干细胞",
      "definition": "具有自我更新和多向分化潜能的未分化细胞，是组织再生的基础。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 26,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_035",
      "name": "干细胞在再生中的作用",
      "definition": "干细胞通过增殖、分化补充受损或死亡的细胞，参与组织修复和再生过程。",
      "category": "生理机制",
      "chapter": "第一节　再生",
      "page": 26,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_036",
      "name": "组织再生的机制",
      "definition": "通过细胞增殖、分化、迁移以及细胞外基质重塑等过程，恢复受损组织的结构和功能。",
      "category": "生理机制",
      "chapter": "第一节　再生",
      "page": 28,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_037",
      "name": "组织再生的过程",
      "definition": "包括炎症反应、细胞增殖、组织重塑等阶段，最终实现组织结构的恢复。",
      "category": "生理机制",
      "chapter": "第一节　再生",
      "page": 28,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_038",
      "name": "细胞再生的影响因素",
      "definition": "影响细胞再生能力的各种内外部因素，包括生长因子、细胞外基质、微环境等。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 30,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_039",
      "name": "生长因子",
      "definition": "调节细胞增殖、分化和迁移的信号分子，是影响细胞再生的关键因素。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 30,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_040",
      "name": "细胞外基质",
      "definition": "由细胞分泌的复杂大分子网络，为细胞提供支架并调控细胞行为，影响再生过程。",
      "category": "解剖结构",
      "chapter": "第一节　再生",
      "page": 30,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    },
    {
      "id": "book_dd048971_node_041",
      "name": "再生微环境",
      "definition": "细胞周围的环境因素总和，包括细胞因子、基质成分、氧气浓度等，决定再生能否成功。",
      "category": "核心概念",
      "chapter": "第一节　再生",
      "page": 30,
      "textbook_id": "book_dd048971",
      "textbook_name": "dd048971"
    }
  ],
