    {
      "id": "book_d9ca034d_node_045",
      "name": "病程发展的阶段性",
      "definition": "传染病病程通常分为潜伏期、前驱期、症状明显期和恢复期四个阶段。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_046",
      "name": "潜伏期",
      "definition": "从病原体侵入人体到出现临床症状的时期，是判断传染病的重要依据。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_047",
      "name": "前驱期",
      "definition": "从出现非特异性症状（如发热、乏力）到典型症状出现前的时期。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_048",
      "name": "症状明显期",
      "definition": "传染病典型症状和体征充分表现的时期，是诊断和治疗的关键阶段。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_049",
      "name": "恢复期",
      "definition": "症状逐渐消退，生理功能和组织损伤逐步恢复的时期。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_050",
      "name": "发热",
      "definition": "传染病最常见的全身症状，热型（如稽留热、弛张热）对诊断有重要价值。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_051",
      "name": "皮疹",
      "definition": "多种传染病的特征性皮肤表现，如斑疹、丘疹、疱疹等，有助于鉴别诊断。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
      "page": 10,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_052",
      "name": "传染病诊断",
      "definition": "综合临床资料、流行病学资料和实验室检查资料，对传染病进行判断和鉴别的过程。",
      "category": "核心概念",
      "chapter": "第五节 传染病的诊断",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_053",
      "name": "临床资料",
      "definition": "通过问诊、体格检查获得的患者症状、体征等临床信息，是传染病诊断的基础。",
      "category": "核心概念",
      "chapter": "第五节 传染病的诊断",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_054",
      "name": "流行病学资料",
      "definition": "包括患者的接触史、疫区旅居史、发病季节、人群易感性等信息，对传染病诊断有重要提示作用。",
      "category": "核心概念",
      "chapter": "第五节 传染病的诊断",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_055",
      "name": "实验室及其他检查资料",
      "definition": "通过病原学、血清学、分子生物学及影像学等检查获得的客观证据，是确诊传染病的关键。",
      "category": "核心概念",
      "chapter": "第五节 传染病的诊断",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_056",
      "name": "病原学检查",
      "definition": "直接检测病原体（如细菌、病毒）或其抗原、核酸的方法，是传染病诊断的金标准。",
      "category": "实验室检查",
      "chapter": "第五节 传染病的诊断",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_057",
      "name": "血清学检查",
      "definition": "检测患者血清中特异性抗体（IgM、IgG）或抗原，用于判断现症感染或既往感染。",
      "category": "实验室检查",
      "chapter": "第五节 传染病的诊断",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
