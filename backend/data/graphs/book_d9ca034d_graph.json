{
  "textbook_id": "book_d9ca034d",
  "textbook_name": "d9ca034d",
  "nodes": [
    {
      "id": "book_d9ca034d_node_001",
      "name": "感染的概念",
      "definition": "病原体侵入人体并在体内生长繁殖，导致机体产生病理生理反应的过程。",
      "category": "核心概念",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_002",
      "name": "感染过程的表现",
      "definition": "病原体侵入人体后，根据病原体与宿主相互作用的不同结果，可表现为不同形式，如隐性感染、显性感染等。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_003",
      "name": "隐性感染",
      "definition": "病原体侵入人体后，仅引起机体产生特异性免疫应答，不引起或只引起轻微的组织损伤，无临床症状。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_004",
      "name": "显性感染",
      "definition": "病原体侵入人体后，引起明显的组织损伤和病理生理变化，出现特有的临床症状。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_005",
      "name": "病原体携带状态",
      "definition": "病原体在人体内持续存在，但不引起临床症状，宿主可排出病原体成为传染源。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_006",
      "name": "潜伏性感染",
      "definition": "病原体侵入人体后，潜伏于某些部位，当机体免疫功能下降时才引起显性感染。",
      "category": "临床表现",
      "chapter": "第一节　感染与免疫",
      "page": 2,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_007",
      "name": "感染过程中病原体的作用",
      "definition": "病原体通过其毒力、侵袭力、数量及变异性等因素影响感染过程的发生和发展。",
      "category": "病理变化",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_008",
      "name": "病原体毒力",
      "definition": "病原体产生毒素（内毒素、外毒素）的能力，是决定致病性强弱的重要因素。",
      "category": "病理变化",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_009",
      "name": "病原体侵袭力",
      "definition": "病原体突破宿主防御屏障、在体内扩散和繁殖的能力。",
      "category": "病理变化",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_010",
      "name": "病原体数量",
      "definition": "侵入人体的病原体数量，通常数量越大，感染越容易发生且病情越重。",
      "category": "病理变化",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_011",
      "name": "病原体变异性",
      "definition": "病原体在感染过程中发生基因变异，可改变其抗原性、毒力或耐药性，影响感染转归。",
      "category": "病理变化",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_012",
      "name": "感染过程中免疫应答的作用",
      "definition": "宿主免疫系统对病原体产生的防御反应，包括非特异性免疫和特异性免疫，决定感染结局。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_013",
      "name": "非特异性免疫",
      "definition": "机体先天具有的防御机制，包括皮肤黏膜屏障、吞噬细胞、补体等，对多种病原体均有作用。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_014",
      "name": "特异性免疫",
      "definition": "机体针对特定病原体产生的后天获得性免疫，包括细胞免疫和体液免疫，具有记忆性。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_015",
      "name": "细胞免疫",
      "definition": "由T淋巴细胞介导的免疫应答，主要清除细胞内病原体，如病毒、结核杆菌等。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_016",
      "name": "体液免疫",
      "definition": "由B淋巴细胞产生抗体介导的免疫应答，主要清除细胞外病原体及其毒素。",
      "category": "生理机制",
      "chapter": "第一节　感染与免疫",
      "page": 4,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_017",
      "name": "传染病的发生与发展",
      "definition": "病原体侵入人体后，经历潜伏期、前驱期、症状明显期和恢复期等阶段，逐步引起机体感染和疾病发展的过程。",
      "category": "核心概念",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_018",
      "name": "组织损伤的发生机制",
      "definition": "病原体及其毒素、免疫反应等因素导致宿主组织细胞结构和功能破坏的病理过程。",
      "category": "病理变化",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_019",
      "name": "重要的病理生理变化",
      "definition": "传染病过程中出现的全身性或局部性功能代谢紊乱，如发热、炎症、代谢改变等。",
      "category": "生理机制",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_020",
      "name": "潜伏期",
      "definition": "从病原体侵入人体到出现临床症状之前的时期，是传染病发生与发展的起始阶段。",
      "category": "核心概念",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_021",
      "name": "前驱期",
      "definition": "潜伏期后出现非特异性症状（如乏力、低热）的阶段，为传染病典型症状出现前的过渡期。",
      "category": "临床表现",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_022",
      "name": "症状明显期",
      "definition": "传染病特异性症状和体征最突出的阶段，是疾病的高峰期。",
      "category": "临床表现",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_023",
      "name": "恢复期",
      "definition": "症状逐渐消退，机体功能开始恢复的阶段，部分患者可能遗留后遗症。",
      "category": "临床表现",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_024",
      "name": "病原体直接损伤",
      "definition": "病原体在宿主细胞内增殖或释放毒素，直接破坏细胞结构和功能，导致组织损伤。",
      "category": "病理变化",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_025",
      "name": "免疫病理损伤",
      "definition": "宿主免疫系统对病原体或自身抗原产生过度或异常反应，导致组织损伤，如超敏反应、自身免疫。",
      "category": "病理变化",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_026",
      "name": "发热",
      "definition": "病原体或其产物刺激机体产生致热原，引起体温调定点上移，是传染病常见的病理生理变化。",
      "category": "生理机制",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_027",
      "name": "炎症反应",
      "definition": "机体对病原体入侵的防御性反应，表现为红、肿、热、痛和功能障碍，是组织损伤的重要机制。",
      "category": "生理机制",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_028",
      "name": "代谢紊乱",
      "definition": "传染病期间因发热、炎症等导致糖、脂肪、蛋白质代谢异常，如分解代谢增强、负氮平衡。",
      "category": "生理机制",
      "chapter": "第二节　传染病的发病机制",
      "page": 12,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_029",
      "name": "传染病的流行过程",
      "definition": "传染病在人群中发生、传播和终止的过程，包括病原体从传染源排出，经过传播途径，侵入易感者体内并引起感染的过程。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_030",
      "name": "流行过程的基本条件",
      "definition": "传染病流行必须具备的三个基本环节：传染源、传播途径和易感人群，三者缺一不可。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_031",
      "name": "传染源",
      "definition": "体内有病原体生长、繁殖并能排出病原体的人或动物，包括患者、病原携带者和受感染的动物。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_032",
      "name": "传播途径",
      "definition": "病原体从传染源排出后，侵入易感者机体所经过的途径或方式，如空气、水、食物、接触等。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_033",
      "name": "易感人群",
      "definition": "对某种传染病缺乏免疫力，容易感染该病的人群，其易感性受年龄、免疫状态、遗传等因素影响。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_034",
      "name": "影响流行过程的因素",
      "definition": "影响传染病流行过程发生、发展和结局的各种自然因素和社会因素，包括气候、地理、人口流动、卫生条件等。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 8,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_035",
      "name": "自然因素",
      "definition": "影响传染病流行的自然环境因素，如气候、季节、地理环境、媒介生物等，可影响病原体存活和传播。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 8,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_036",
      "name": "社会因素",
      "definition": "影响传染病流行的社会环境因素，如人口密度、卫生设施、医疗水平、生活习惯、交通等。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 8,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_037",
      "name": "流行过程的基本条件三环节",
      "definition": "传染源、传播途径和易感人群三个基本环节共同构成传染病流行过程的基础，缺一不可。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_038",
      "name": "流行过程的动态性",
      "definition": "传染病流行过程不是静止的，而是受多种因素影响不断变化的动态过程，包括流行强度、时间分布等。",
      "category": "核心概念",
      "chapter": "第三节　传染病的流行过程及影响因素",
      "page": 7,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_039",
      "name": "传染病的基本特征",
      "definition": "传染病区别于其他疾病的特有属性，包括病原体、传染性、流行病学特征和感染后免疫。",
      "category": "核心概念",
      "chapter": "第四节　传染病的特征",
      "page": 9,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_040",
      "name": "病原体",
      "definition": "引起传染病的微生物或寄生虫，是传染病发生的必要条件。",
      "category": "核心概念",
      "chapter": "第四节　传染病的特征",
      "page": 9,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_041",
      "name": "传染性",
      "definition": "病原体从宿主排出后，经一定途径侵入他人体内引起感染的能力。",
      "category": "核心概念",
      "chapter": "第四节　传染病的特征",
      "page": 9,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_042",
      "name": "流行病学特征",
      "definition": "传染病在人群中发生、传播和分布的规律，包括流行性、季节性、地方性等。",
      "category": "核心概念",
      "chapter": "第四节　传染病的特征",
      "page": 9,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_043",
      "name": "感染后免疫",
      "definition": "人体感染病原体后产生的特异性免疫力，可防止同种病原体再次感染。",
      "category": "核心概念",
      "chapter": "第四节　传染病的特征",
      "page": 9,
      "textbook_id": "book_d9ca034d",
      "textbook_name": "d9ca034d"
    },
    {
      "id": "book_d9ca034d_node_044",
      "name": "传染病的临床特点",
      "definition": "传染病在临床表现上的共同特征，包括病程发展的阶段性、发热、皮疹等。",
      "category": "临床表现",
      "chapter": "第四节　传染病的特征",
