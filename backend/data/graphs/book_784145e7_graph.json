    {
      "id": "book_784145e7_node_001",
      "name": "境界与分区",
      "definition": "描述人体解剖学中不同区域或部位的边界划分和区域划分方法。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 9,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_002",
      "name": "表面解剖",
      "definition": "通过观察和触摸人体表面，识别内部器官、骨骼、血管等结构的位置和体表投影。",
      "category": "核心概念",
      "chapter": "第一节 概述",
      "page": 9,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_003",
      "name": "面部浅层结构",
      "definition": "面部皮肤、浅筋膜、表情肌及浅层血管、神经等结构的总称。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_004",
      "name": "面侧区",
      "definition": "面部两侧的区域，包含腮腺、咬肌、面神经等深层重要结构。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_005",
      "name": "面部的间隙",
      "definition": "面部筋膜之间或筋膜与肌肉、骨膜之间的潜在腔隙，如咬肌间隙、翼下颌间隙等。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 19,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_006",
      "name": "面部皮肤",
      "definition": "面部最外层结构，富含皮脂腺、汗腺，血供丰富，与浅筋膜连接紧密。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_007",
      "name": "浅筋膜",
      "definition": "位于皮肤深面的疏松结缔组织，内含表情肌、血管、神经和脂肪。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_008",
      "name": "表情肌",
      "definition": "属于皮肌，起于骨面或筋膜，止于皮肤，收缩时牵动皮肤产生表情。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_009",
      "name": "腮腺",
      "definition": "位于面侧区耳前下方的最大唾液腺，其浅面有皮肤、浅筋膜覆盖。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_010",
      "name": "咬肌",
      "definition": "位于面侧区，起于颧弓，止于下颌角，是重要的咀嚼肌。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_011",
      "name": "面神经",
      "definition": "第七对脑神经，穿经腮腺后分支支配表情肌，是面侧区重要神经。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 13,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_012",
      "name": "咬肌间隙",
      "definition": "位于咬肌与下颌支之间的潜在间隙，是面部常见感染扩散部位。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 19,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_013",
      "name": "翼下颌间隙",
      "definition": "位于翼内肌与下颌支之间的间隙，内有下牙槽神经、血管通过。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 19,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_014",
      "name": "面部浅层血管",
      "definition": "包括面动脉、面静脉等，分布于面部浅层，提供血供并参与回流。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_015",
      "name": "面部浅层神经",
      "definition": "包括三叉神经分支（眶上、眶下、颏神经）及面神经分支，司感觉和运动。",
      "category": "解剖结构",
      "chapter": "第二节 面部",
      "page": 11,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_016",
      "name": "颅部",
      "definition": "人体头部的一部分，包含颅骨、脑及脑膜等结构，是中枢神经系统的保护区域。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_017",
      "name": "颅底内面",
      "definition": "颅骨内侧面，分为颅前窝、颅中窝和颅后窝，容纳并保护脑组织。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_018",
      "name": "颅前窝",
      "definition": "颅底内面前部，容纳额叶，由额骨、筛骨和蝶骨小翼构成。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_019",
      "name": "颅中窝",
      "definition": "颅底内面中部，容纳颞叶，由蝶骨和颞骨构成，包含垂体窝等重要结构。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_020",
      "name": "颅后窝",
      "definition": "颅底内面后部，容纳小脑和脑干，由枕骨和颞骨岩部构成。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_021",
      "name": "颅骨",
      "definition": "构成颅部的骨骼，包括脑颅骨和面颅骨，保护脑和感觉器官。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_022",
      "name": "脑",
      "definition": "中枢神经系统的主要部分，位于颅腔内，包括大脑、小脑和脑干。",
      "category": "核心概念",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_023",
      "name": "脑膜",
      "definition": "包裹脑和脊髓的三层结缔组织膜，包括硬脑膜、蛛网膜和软脑膜。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_024",
      "name": "硬脑膜",
      "definition": "脑膜最外层，厚而坚韧，紧贴颅骨内面，形成静脉窦。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_025",
      "name": "蛛网膜",
      "definition": "脑膜中层，薄而透明，与软脑膜之间形成蛛网膜下隙，充满脑脊液。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_026",
      "name": "软脑膜",
      "definition": "脑膜最内层，薄而富含血管，紧贴脑表面并深入脑沟。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_027",
      "name": "颅底骨折",
      "definition": "颅底骨质因外伤发生断裂，常累及颅前窝、颅中窝或颅后窝，可导致脑脊液漏。",
      "category": "病理变化",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_028",
      "name": "脑脊液漏",
      "definition": "颅底骨折后，脑脊液经破裂的硬脑膜和骨质漏出至鼻腔或外耳道。",
      "category": "临床表现",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_029",
      "name": "垂体窝",
      "definition": "颅中窝蝶骨体上的凹陷，容纳脑垂体。",
      "category": "解剖结构",
      "chapter": "第三节 颅部",
      "page": 23,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_030",
      "name": "头部解剖操作",
      "definition": "针对头部区域进行的系统性解剖操作流程，包括面部和颅部两个主要部分。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
      "page": 14,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_031",
      "name": "解剖面部",
      "definition": "头部解剖操作中对面部区域进行解剖的具体步骤和方法。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
      "page": 30,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_032",
      "name": "解剖颅部",
      "definition": "头部解剖操作中对颅部区域进行解剖的具体步骤和方法。",
      "category": "核心概念",
      "chapter": "第四节 头部解剖操作",
      "page": 33,
      "textbook_id": "book_784145e7",
      "textbook_name": "784145e7"
    },
    {
      "id": "book_784145e7_node_033",
      "name": "境界与分区",
      "definition": "描述人体某一局部区域的边界范围以及内部划分的亚区，是解剖学定位的基础。",
      "category": "核心概念",
