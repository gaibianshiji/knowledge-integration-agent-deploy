    },
    {
      "id": "book_35a90284_node_056",
      "name": "因果交替",
      "definition": "疾病过程中，原因和结果相互转化、交替出现，推动疾病发展的规律。",
      "category": "病理变化",
      "chapter": "第三节",
      "page": 10,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_057",
      "name": "局部与整体",
