      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_054",
      "name": "疾病发生发展的基本机制",
      "definition": "导致疾病发生、发展的具体生物学过程和分子机制。",
