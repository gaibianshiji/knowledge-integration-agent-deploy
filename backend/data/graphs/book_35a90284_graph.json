{
  "textbook_id": "book_35a90284",
  "textbook_name": "35a90284",
  "nodes": [
    {
      "id": "book_35a90284_node_001",
      "name": "病理生理学",
      "definition": "研究疾病发生、发展过程中机体功能、代谢变化及其机制的学科，是基础医学与临床医学之间的桥梁学科。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_002",
      "name": "发展简史",
      "definition": "病理生理学作为独立学科的形成和发展历程，包括早期萌芽、学科建立及现代发展阶段。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_003",
      "name": "未来趋势",
      "definition": "病理生理学在分子生物学、系统生物学、精准医学等新技术推动下的发展方向和前沿领域。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_004",
      "name": "学科萌芽期",
      "definition": "19世纪以前，基于尸体解剖和临床观察对疾病机制进行初步探索的阶段。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_005",
      "name": "学科建立期",
      "definition": "19世纪末至20世纪初，病理生理学作为独立学科在欧洲（尤其是俄罗斯）正式建立，并开始系统教学。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_006",
      "name": "现代发展期",
      "definition": "20世纪中叶至今，随着分子生物学、免疫学、遗传学等发展，病理生理学进入分子和细胞水平研究阶段。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_007",
      "name": "分子病理生理学",
      "definition": "从分子水平研究疾病发生发展机制的病理生理学分支，关注基因、蛋白质等生物大分子的变化。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_008",
      "name": "系统病理生理学",
      "definition": "从系统生物学角度，整合基因组、蛋白质组、代谢组等多层次信息，研究疾病整体规律的学科方向。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_009",
      "name": "精准医学",
      "definition": "基于个体基因、环境、生活方式等差异，为疾病预防、诊断和治疗提供个性化方案的医学模式。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_010",
      "name": "转化医学",
      "definition": "将基础研究成果快速转化为临床应用的医学研究模式，强调从实验室到病床的转化过程。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_011",
      "name": "疾病模型",
      "definition": "在实验动物或细胞上模拟人类疾病状态，用于研究发病机制和药物筛选的研究工具。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_012",
      "name": "生物信息学",
      "definition": "运用计算机和信息技术处理、分析生物医学大数据，揭示疾病相关分子机制的交叉学科。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_013",
      "name": "基因编辑技术",
      "definition": "通过CRISPR/Cas9等工具对生物体基因组进行精确修饰的技术，用于研究基因功能及疾病治疗。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_014",
      "name": "单细胞测序",
      "definition": "对单个细胞进行基因组或转录组测序的技术，可揭示细胞异质性和疾病微环境。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_015",
      "name": "人工智能在病理生理学中的应用",
      "definition": "利用机器学习、深度学习等AI技术分析病理生理数据，辅助疾病诊断、预测和机制研究。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_016",
      "name": "病理生理学",
      "definition": "研究疾病发生、发展过程中功能、代谢变化及其机制的学科",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_017",
      "name": "主要教学内容",
      "definition": "病理生理学课程的核心学习内容，包括疾病概论、基本病理过程和各系统病理生理学",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_018",
      "name": "疾病概论",
      "definition": "研究疾病发生发展的一般规律和基本机制的概论性内容",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_019",
      "name": "基本病理过程",
      "definition": "多种疾病中可能出现的共同的功能、代谢和形态结构变化",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_020",
      "name": "各系统病理生理学",
      "definition": "研究各系统器官疾病发生发展的具体机制和功能代谢变化",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_021",
      "name": "病理生理学研究手段概述",
      "definition": "用于研究疾病机制和病理过程的各种实验和临床研究方法",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_022",
      "name": "实验研究",
      "definition": "通过动物模型、细胞培养等实验手段研究疾病机制的方法",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_023",
      "name": "临床研究",
      "definition": "直接观察和分析患者疾病过程及治疗效果的研究方法",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_024",
      "name": "学习方法",
      "definition": "学习病理生理学课程的有效策略和技巧",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_025",
      "name": "功能代谢变化",
      "definition": "疾病过程中机体器官功能及物质代谢发生的异常改变",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_026",
      "name": "疾病机制",
      "definition": "疾病发生、发展的内在机理和分子基础",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_027",
      "name": "疾病发生发展规律",
      "definition": "疾病从发生到结局所遵循的普遍规律和基本过程",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_028",
      "name": "健康",
      "definition": "不仅是没有疾病和虚弱，而且是身体、心理和社会适应方面的完好状态。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_029",
      "name": "疾病",
      "definition": "机体在一定病因作用下，自稳调节紊乱而发生的异常生命活动过程，表现为症状、体征和行为异常。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_030",
      "name": "亚健康",
      "definition": "介于健康与疾病之间的一种生理功能低下的状态，又称第三状态或灰色状态。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_031",
      "name": "健康-疾病连续谱",
      "definition": "健康和疾病是一个动态连续的过程，从最佳健康到死亡之间存在一系列过渡状态。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_032",
      "name": "身体完好状态",
      "definition": "健康的一个维度，指机体各系统器官功能正常，无器质性或功能性异常。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_033",
      "name": "心理完好状态",
      "definition": "健康的一个维度，指个体情绪稳定、认知正常、人格完整，能有效应对压力。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_034",
      "name": "社会适应完好状态",
      "definition": "健康的一个维度，指个体能有效扮演社会角色，与他人和谐相处，参与社会活动。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_035",
      "name": "自稳调节紊乱",
      "definition": "疾病发生的核心机制，指机体内部稳态调节机制失效，导致内环境失衡。",
      "category": "病理变化",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_036",
      "name": "第三状态",
      "definition": "亚健康的别称，强调其既非健康也非疾病的中间过渡性质。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_037",
      "name": "灰色状态",
      "definition": "亚健康的另一种形象化表述，指健康与疾病之间的模糊地带。",
      "category": "核心概念",
      "chapter": "第一节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_038",
      "name": "病因学",
      "definition": "研究疾病发生的原因和条件的科学，是病理学的基础分支。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_039",
      "name": "疾病发生的原因",
      "definition": "引起疾病并决定疾病特异性的因素，包括生物性、物理性、化学性、营养性、遗传性等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_040",
      "name": "疾病发生的条件",
      "definition": "影响疾病发生、发展的各种内外环境因素，可促进或阻碍疾病的发生。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_041",
      "name": "危险因素",
      "definition": "增加疾病发生概率的特定条件或因素，是疾病发生的促进因素。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_042",
      "name": "生物性致病因素",
      "definition": "包括病原微生物（细菌、病毒、真菌等）和寄生虫，是最常见的病因。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_043",
      "name": "物理性致病因素",
      "definition": "包括机械力、温度、辐射、电流等物理因素引起的损伤。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_044",
      "name": "化学性致病因素",
      "definition": "包括强酸、强碱、毒物、药物等化学物质对机体的损害。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_045",
      "name": "营养性致病因素",
      "definition": "包括营养缺乏（如维生素缺乏）或营养过剩导致的疾病。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_046",
      "name": "遗传性致病因素",
      "definition": "由基因突变或染色体异常引起的疾病因素。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_047",
      "name": "免疫性致病因素",
      "definition": "包括自身免疫反应、过敏反应等免疫异常导致的疾病。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_048",
      "name": "精神心理致病因素",
      "definition": "包括长期精神紧张、情绪波动等心理因素对疾病发生的影响。",
      "category": "病理变化",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_049",
      "name": "疾病发生的条件分类",
      "definition": "包括内部条件（如年龄、性别、遗传易感性）和外部条件（如环境、社会因素）。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_050",
      "name": "诱因",
      "definition": "能加强病因作用或促进疾病发生的条件，如受凉、劳累等。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_051",
      "name": "病因与条件的关系",
      "definition": "病因决定疾病特异性，条件影响疾病发生与否，二者共同作用导致疾病。",
      "category": "核心概念",
      "chapter": "第二节",
      "page": 16,
      "textbook_id": "book_35a90284",
      "textbook_name": "35a90284"
    },
    {
      "id": "book_35a90284_node_052",
      "name": "发病学基础",
      "definition": "研究疾病发生、发展及转归的基本原理和规律，是病理生理学的核心内容之一。",
      "category": "核心概念",
      "chapter": "第三节",
      "page": 10,
      "textbook_id": "book_35a90284",
